{
  "manifest_version": 3,
  "name": "Xiangqi Bot Helper",
  "version": "0.1.0",
  "description": "Hoc tap: phan tich the co va goi y nuoc di voi Pikafish",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://play.xiangqi.com/*",
    "http://127.0.0.1:8080/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://play.xiangqi.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Xiangqi Bot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
